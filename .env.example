# Copy this file to .env and fill in your actual Supabase project values.
# Find both under: Supabase Dashboard → Project Settings → Data API
#
# VITE_SUPABASE_URL is safe to expose in frontend code — it's just your
# project's address, not a secret.
#
# VITE_SUPABASE_ANON_KEY is also meant to be public/embedded in frontend
# apps — Supabase's security model relies on Row Level Security policies
# and the password-gated RPC functions (see supabase/schema.sql), not on
# hiding this key.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
